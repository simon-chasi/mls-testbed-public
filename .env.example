# Copy to .env to override defaults when running via Docker Compose.
# The SEED controls the PRNG for scenario operations — same seed = same scenario structure.
# Note: cryptographic randomness in mls-rs is NOT seeded (correct by design).
#
# Docker Compose picks up a .env file in this directory automatically.
# The paths below are the in-container paths set in docker-compose.yml;
# you only need to set SEED here.

SEED=42
